---
import BaseLayout from "../../layouts/BaseLayout.astro";

export const prerender = true;

const title = "视频作品 | 二两碘酊 MichaelWong";
---

<BaseLayout title={title}>
  <div class="video-bg-lights" aria-hidden="true">
    <div class="light-source red-light-large"></div>
    <div class="light-source blue-light-small"></div>
  </div>
  <section class="video-container">
    <div class="page-title-row">
      <h1 class="page-title">
        <span id="typewriter"></span>
      </h1>
      <span class="page-title-zh">视频作品</span>
    </div>
    <p class="page-subtitle">
      收录了二两碘酊迄今为止的所有视频作品，包括个人创作、参赛作品与官方项目。
    </p>
    <div class="divider"></div>
    <div class="matrix-title">碘伏社媒矩阵</div>
    <div class="qrcode-list">
      <div class="qrcode-card">
        <img src="/qrcodes/bilibili.png" alt="B站二维码" class="qrcode-img" />
        <div class="qrcode-label">B站</div>
      </div>
      <div class="qrcode-card">
        <img src="/qrcodes/tiktok.png" alt="抖音二维码" class="qrcode-img" />
        <div class="qrcode-label">抖音</div>
      </div>
      <div class="qrcode-card">
        <img src="/qrcodes/weixin.png" alt="视频号二维码" class="qrcode-img" />
        <div class="qrcode-label">视频号</div>
      </div>
    </div>
    <div class="divider"></div>
    <div class="video-section">
      <h2 class="section-title">获奖作品</h2>
      <div class="video-list">
        <div class="video-card beautified">
          <a href="https://www.bilibili.com/video/BV15Y411x7SX" target="_blank" rel="noopener noreferrer">
            <div class="video-info">
              <div class="video-title">一摔就断水的屑圆珠笔？初中生和你讲圆珠笔的历史和原理！【全国最佳作品奖】</div>
              <div class="video-meta">2021-12</div>
            </div>
          </a>
        </div>
        <div class="video-card beautified">
          <a href="https://www.bilibili.com/video/BV1Bv411w7b8" target="_blank" rel="noopener noreferrer">
            <div class="video-info">
              <div class="video-title">轻信的代价【第二十二届全国学生信息素养提升实践活动河北赛区初中组一等奖获奖作品】</div>
              <div class="video-meta">2021-12</div>
            </div>
          </a>
        </div>
        <div class="video-card beautified">
          <a href="https://www.bilibili.com/video/BV15Y411x7SX" target="_blank" rel="noopener noreferrer">
            <div class="video-info">
              <div class="video-title">【第八届全国大学生新媒体大赛二等奖】我找到了几十年前南开学长的信……</div>
              <div class="video-meta">2026-01</div>
            </div>
          </a>
        </div>
      </div>
      <h2 class="section-title">个人风格化作品代表——高强度发病</h2>
      <div class="video-list">
        <div class="video-card beautified">
          <a href="https://www.bilibili.com/video/BV1RL4y1V78R" target="_blank" rel="noopener noreferrer">
            <div class="video-info">
              <div class="video-title">Evade and Evolve</div>
              <div class="video-meta">2022-04</div>
            </div>
          </a>
        </div>
        <div class="video-card beautified">
          <a href="【Miss U.】 https://www.bilibili.com/video/BV1nG4y1R7rY" target="_blank" rel="noopener noreferrer">
            <div class="video-info">
              <div class="video-title">Miss U.</div>
              <div class="video-meta">2022-12</div>
            </div>
          </a>
        </div>
        <div class="video-card beautified">
          <a href="https://www.bilibili.com/video/BV1Pb411Q77f" target="_blank" rel="noopener noreferrer">
            <div class="video-info">
              <div class="video-title">Review & Reflect</div>
              <div class="video-meta">2023-03</div>
            </div>
          </a>
        </div>
      </div>
      <h2 class="section-title">年度总结与班级混剪</h2>
      <div class="video-list">
        <div class="video-card beautified">
          <a href="https://www.bilibili.com/video/BV1bG4y1m7FL" target="_blank" rel="noopener noreferrer">
            <div class="video-info">
              <div class="video-title">致2023年的我</div>
              <div class="video-meta">2022-12-31</div>
            </div>
          </a>
        </div>
        <div class="video-card beautified">
          <a href="https://www.bilibili.com/video/BV1bG4y1m7FL" target="_blank" rel="noopener noreferrer">
            <div class="video-info">
              <div class="video-title">告别2023，这是我今年的故事</div>
              <div class="video-meta">2023-12-31</div>
            </div>
          </a>
        </div>
        <div class="video-card beautified">
          <a href="https://www.bilibili.com/video/BV1AdsSzxE3w" target="_blank" rel="noopener noreferrer">
            <div class="video-info">
              <div class="video-title">祝你成人快乐！</div>
              <div class="video-meta">2025-10-29</div>
            </div>
          </a>
        </div>
         <div class="video-card beautified">
          <a href="https://www.bilibili.com/video/BV12ziMBsECB" target="_blank" rel="noopener noreferrer">
            <div class="video-info">
              <div class="video-title">从唐山一中到南开大学，这是我的 2025。</div>
              <div class="video-meta">2025-12-31</div>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>
  <script src="https://unpkg.com/typed.js@2.1.0/dist/typed.umd.js"></script>
  <script>
    declare const Typed: any;
    document.addEventListener('DOMContentLoaded', () => {
      new Typed('#typewriter', {
        strings: ["Video Projects"],
        typeSpeed: 80,
        startDelay: 300,
        backDelay: 2500,
        loop: false,
        showCursor: true
      });
    });
  </script>
  <style>
    .video-container {
      max-width: 1200px;
      margin-left: 10vw;
      margin-right: 5vw;
      padding-top: 15vh;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      position: relative;
      z-index: 1;
    }
    .page-title-row {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.2rem;
      margin: 0 0 0.5rem 0;
    }
    .page-title {
      font-family: 'Bodoni Moda', 'Noto Serif SC', serif;
      font-size: 3rem;
      font-weight: 420;
      font-variation-settings: "opsz" var(--bodoni-opsz), "wght" 420;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
      margin: 0;
      height: 3.5rem;
      letter-spacing: 0.05em;
    }
    .page-title-zh {
      font-family: 'Noto Serif SC', serif;
      font-size: 1.45rem;
      font-weight: 700;
      letter-spacing: 0.35em;
      color: rgba(255,255,255,0.85);
      white-space: nowrap;
      margin-top: 2rem;
    }
    .page-title .typed-cursor {
      font-size: 3rem;
      color: var(--text-primary);
      font-family: 'Bodoni Moda', serif;
      font-weight: 300;
      animation: typedjsBlink 0.7s infinite;
    }
    @keyframes typedjsBlink {
      0%, 50%, 100% { opacity: 1; }
      25%, 75% { opacity: 0; }
    }
    .page-subtitle {
      font-family: 'Noto Sans SC', sans-serif;
      font-size: 1.08rem;
      letter-spacing: 0.12em;
      color: rgba(255,255,255,0.5);
      margin-bottom: 2rem;
      margin-top: 0.2rem;
    }
    .divider {
      width: 60px;
      height: 1px;
      background: rgba(255,255,255,0.3);
      margin-bottom: 3rem;
    }
    .matrix-title {
      font-size: 1.4rem;
      font-weight: 600;
      color: #fff;
      margin: 2.2rem 0 2.2rem 0;
      letter-spacing: 0.09em;
      font-family: 'Noto Serif SC', serif;
    }
    .qrcode-list {
      display: flex;
      gap: 2.5rem;
      margin-bottom: 2.5rem;
    }
    .qrcode-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.13);
      border-radius: 8px;
      padding: 1.2rem 1.5rem 1rem 1.5rem;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }
    .qrcode-img {
      background: #fff;
      border-radius: 8px;
      margin-bottom: 0.7rem;
      display: block;
      max-width: 250px;
      max-height: 250px;
      width: 100%;
      height: auto;
      box-shadow: 0 2px 8px rgba(0,0,0,0.10);
      border: 1px solid rgba(0,0,0,0.06);
      object-fit: contain;
    }
    .qrcode-label {
      font-size: 1.05rem;
      color: #fff;
      margin-top: 0.2rem;
      letter-spacing: 0.06em;
    }
    .section-title {
      font-size: 1.4rem;
      color: #fff;
      margin: 2.5rem 0 2.2rem 0;
      letter-spacing: 0.08em;
      font-family: 'Noto Serif SC', serif;
      font-weight: 600;
    }
    .video-list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 2.5rem;
      justify-items: center;
    }
    .video-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 10px;
      overflow: hidden;
      width: 320px;
      box-shadow: 0 4px 16px rgba(0,0,0,0.12);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .video-card:hover {
      transform: translateY(-6px) scale(1.03);
      box-shadow: 0 8px 32px rgba(0,0,0,0.18);
    }
    .video-card.beautified {
      background: rgba(255,255,255,0.06);
      border: 1.5px solid rgba(255,255,255,0.13);
      border-radius: 18px;
      box-shadow: 0 6px 32px rgba(0,0,0,0.13);
      padding: 2.2rem 2.5rem 1.7rem 2.5rem;
      min-width: 320px;
      max-width: 480px;
      margin: 0 auto;
      transition: box-shadow 0.2s, transform 0.2s;
    }
    .video-card.beautified:hover {
      box-shadow: 0 12px 48px rgba(0,0,0,0.22);
      border-color: #fff;
      transform: translateY(-6px) scale(1.03);
    }
    .video-card.beautified a {
      text-decoration: none;
      color: inherit;
    }
    .video-card.beautified a:visited {
      color: inherit;
    }
    .video-cover {
      width: 100%;
      height: 180px;
      object-fit: cover;
      display: block;
    }
    .video-info {
      padding: 1rem;
      display: flex;
      flex-direction: column;
      gap: 1.1rem;
      align-items: flex-start;
    }
    .video-title {
      font-size: 1.18rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: 0.2rem;
      letter-spacing: 0.04em;
    }
    .video-meta {
      font-size: 1.02rem;
      color: rgba(255,255,255,0.55);
      border-top: 1px solid rgba(255,255,255,0.13);
      padding-top: 0.7rem;
      margin-top: 0.2rem;
      width: 100%;
    }
    @media (max-width: 900px) {
      .video-list {
        flex-direction: column;
        gap: 1.5rem;
      }
      .video-card {
        width: 100%;
      }
      .video-cover {
        height: 200px;
      }
    }
  </style>
</BaseLayout>
