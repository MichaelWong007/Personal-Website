---
import BaseLayout from "../layouts/BaseLayout.astro";

export const prerender = true;

const title = "About 关于 | 二两碘酊 MichaelWong";
const description = "关于二两碘酊 MichaelWong，字端复，自号穑斋主人。了解更多关于这位钟爱视听逻辑文字美学与计算机艺术的热血青年的信息，包括社交媒体链接和作品集。";
---

<BaseLayout 
  title={title}
  description={description}
  keywords="二两碘酊,MichaelWong,穑斋主人,端复,关于,个人简介,联系方式"
>
  <div class="about-bg-lights" aria-hidden="true">
    <div class="light-source about-red-light"></div>
    <div class="light-source about-blue-light"></div>
  </div>

  <section class="about-container">
    <div class="about-content">
      
      <!-- Logo 展示区 -->
      <div class="logo-section">
        <img src="https://pic1.imgdb.cn/item/6995d39a556e27f1c93a3414.png" alt="二两碘酊 MichaelWong Logo" class="about-logo" />
      </div>

      <!-- 标题区 -->
      <div class="header-section">
        <h1 class="page-title">关 于</h1>
        <h2 class="page-subtitle">About</h2>
      </div>

      <!-- 自我介绍区 -->
      <div class="intro-section">
        <p>
          从 <span class="latin-text">LaTeX</span> 到 <span class="latin-text">C++</span>，从 平面设计与视频剪辑 到 诗词歌赋——
        </p>
        <p>
          朋友你好，我是 <strong>二两碘酊 <span class="latin-text">MichaelWong</span></strong>，一位钟爱各类视听逻辑文字美学与计算机艺术的热血青年。
        </p>
        <p>
          字端复，自号穑斋主人。中文区网名一直叫二两碘酊，外文优先使用 <span class="latin-text">MichaelWong</span>，视场合可能使用 <span class="latin-text">Iodine Tincture</span> 或 <span class="latin-text">IOTynC</span>. 喜欢搞点诗歌创作、程序设计、视频剪辑……
        </p>
        <p>
          欢迎你来到这里，没什么可以拿来感谢你的。如果你恰好有时间，那就让我们一起坐下；来二两碘酊，我们聊点有意思的。
        </p>
      </div>

      <!-- 社交链接区 -->
      <div class="social-section">
        <h3 class="section-title">在其他地方找到我</h3>
        
        <div class="bento-container">
          
          <!-- 编程与算法 -->
          <div class="bento-group-divider"></div>
          <div class="bento-grid">
            <a href="https://github.com/MichaelWong007" target="_blank" rel="noopener noreferrer" class="bento-card large github">
