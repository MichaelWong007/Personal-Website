<style>
  :global(.light-source) {
    display: none;
  }
  
  .about-bg-lights {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .about-red-light {
    display: block !important;
    position: absolute;
    width: 55vw;
    height: 55vw;
    background-color: #6d0e11;
    opacity: 0.7;
    mix-blend-mode: screen;
    bottom: 15vw;
    right: 30vw;
    border-radius: 50%;
    filter: blur(120px);
    animation: pulseRedLight 10s ease-in-out infinite;
  }

  .about-blue-light {
    display: block !important;
    position: absolute;
    width: 55vw;
    height: 55vw;
    background-color: #00094b;
    opacity: 0.9;
    mix-blend-mode: screen;
    bottom: 15vw;
    right: 12vw;
    border-radius: 50%;
    filter: blur(120px);
    animation: pulseBlueLight 14s ease-in-out infinite;
  }

  @keyframes pulseRedLight {
    0%, 100% { opacity: 0.7; transform: scale(1); }
    50% { opacity: 0.3; transform: scale(1.1); }
  }

  @keyframes pulseBlueLight {
    0%, 100% { opacity: 0.9; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(1.15); }
  }

  .about-container {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 0 auto;
    padding: 15vh 5vw 10vh;
    min-height: 100vh;
    color: var(--text-primary);
  }

  .about-content {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .logo-section {
    display: flex;
    justify-content: center;
    margin-bottom: 1rem;
    animation: fadeInUp 0.8s ease-out forwards;
  }

  .about-logo {
    width: 240px;
    height: auto;
    filter: drop-shadow(0 0 20px rgba(255, 255, 255, 0.2));
    transition: transform 0.5s ease, filter 0.5s ease;
  }

  .about-logo:hover {
    transform: scale(1.05);
    filter: drop-shadow(0 0 30px rgba(255, 255, 255, 0.4));
  }

  .header-section {
    text-align: center;
    animation: fadeInUp 0.8s ease-out 0.2s forwards;
    opacity: 0;
  }

  .page-title {
    font-family: "Noto Serif SC", serif;
    font-size: 3rem;
    font-weight: 700;
    margin: -2.5rem 0 0.5rem 0;
    letter-spacing: 0.1em;
  }

  .page-subtitle {
    font-family: "Bodoni Moda", serif;
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.6);
    letter-spacing: 0.2em;
    margin: 0;
    font-weight: 400;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .intro-section {
    font-family: "Noto Serif SC", serif;
    font-size: 1.1rem;
    line-height: 2;
    color: rgba(255, 255, 255, 0.85);
    background: rgba(255, 255, 255, 0.03);
    padding: 2.5rem;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
    animation: fadeInUp 0.8s ease-out 0.4s forwards;
    opacity: 0;
    transition: all 0.3s ease;
  }

  .intro-section:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.15);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  }

  .intro-section p {
    margin: 0 0 1.5rem 0;
    text-indent: 2em;
  }

  .intro-section p:last-child {
    margin-bottom: 0;
  }

  .intro-section strong {
    color: #fff;
    font-weight: 700;
  }

  .intro-section .latin-text {
    font-family: "Bodoni Moda", serif;
    font-style: normal;
  }

  .intro-section strong .latin-text {
    font-family: "Bodoni Moda", serif;
    font-weight: 700;
  }

  .social-section {
    margin-top: 1rem;
    animation: fadeInUp 0.8s ease-out 0.6s forwards;
    opacity: 0;
  }

  .section-title {
    font-family: "Noto Serif SC", serif;
    font-size: 1.6rem;
    font-weight: 600;
    margin: 0 0 2.5rem 0;
    text-align: center;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.95);
    position: relative;
    padding-bottom: 1rem;
    text-shadow: 0 2px 10px rgba(255, 255, 255, 0.1);
  }

  .section-title::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.5), transparent);
    border-radius: 1px;
  }

  /* Bento Grid 样式 */
  .bento-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: minmax(120px, auto);
    gap: 1.5rem;
  }

  .bento-group-divider {
    width: 100%;
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
  }

  /* 默认卡片样式 (1x1 小方块) */
  .bento-card {
    grid-column: span 3;
    grid-row: span 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    text-decoration: none;
    color: var(--text-primary);
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    position: relative;
    overflow: hidden;
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
  }

  /* 2x1 长条卡片 (横向) */
  .bento-card.wide {
    grid-column: span 6;
    flex-direction: row;
    align-items: center;
    justify-content: flex-start;
  }

  .bento-card.wide .bento-info {
    width: calc(100% - 56px - 1rem); /* 减去图标宽度和 gap */
  }

  /* 1x1 小卡片 (横向，半宽) */
  .bento-card.small {
    grid-column: span 3;
    flex-direction: column;
    align-items: flex-start;
